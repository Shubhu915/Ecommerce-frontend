# App
NEXT_PUBLIC_APP_NAME="E-Com AI Store"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# API
NEXT_PUBLIC_API_BASE_URL="http://localhost:5000/api/v1"
NEXT_PUBLIC_IMAGE_BASE_URL="http://localhost:5000/uploads"

# Auth
NEXT_PUBLIC_AUTH_COOKIE_NAME="refresh_token"

# Features
NEXT_PUBLIC_ENABLE_AI_SEARCH="true"
NEXT_PUBLIC_ENABLE_RECOMMENDATIONS="true"

# UI Config
NEXT_PUBLIC_CURRENCY="INR"
NEXT_PUBLIC_DEFAULT_LOCALE="en-IN"
NEXT_PUBLIC_ITEMS_PER_PAGE="10"
NEXT_PUBLIC_SUPPORT_EMAIL="support@ecom.com"
